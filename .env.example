# ── Model tier routing (two tiers, both OpenAI-compatible endpoints) ──
# Cheap tier: Workers (e.g. DeepSeek or Qwen)
CHEAP_MODEL=deepseek-chat
CHEAP_API_KEY=
CHEAP_BASE_URL=https://api.deepseek.com/v1

# Flagship tier: Planner + Synthesizer
FLAGSHIP_MODEL=
FLAGSHIP_API_KEY=
FLAGSHIP_BASE_URL=

# ── Evidence source (D15: local repo via T3 tools — no key needed) ──
# RepoSource reads whatever repo is on disk (defaults to cwd); no config here yet.

# ── Observability (Langfuse, D2 接入 — leave empty for now) ──
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
