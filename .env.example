# ── Model tier routing (two tiers, both OpenAI-compatible endpoints) ──
# Cheap tier: Workers (e.g. DeepSeek or Qwen)
CHEAP_MODEL=deepseek-chat
CHEAP_API_KEY=
CHEAP_BASE_URL=https://api.deepseek.com/v1

# Flagship tier: Planner + Synthesizer
FLAGSHIP_MODEL=
FLAGSHIP_API_KEY=
FLAGSHIP_BASE_URL=

# ── Evidence source (D15: local repo via T3 tools — no key needed) ──
# RepoSource reads whatever repo is on disk (defaults to cwd); no config here yet.

# ── Verifier switch (D3: gate for the open/close citation-error-rate ablation) ──
# 默认关闭=空值即可，行为与还没有 Verifier 这一层完全一致（config.verifier_enabled()）。
# 打开（1/true/yes/on）后对每条 claim 调用 graph._judge_claim 独立核验——今晚只实现了
# 存在性检查（引用的 file:line 是否真实存在），语义判定待 Ziyang 定案后再落地。
VERIFIER_ENABLED=

# ── Observability (Langfuse, wired in at T8 via config.langfuse_handler) ──
# 三个变量任一留空 = 完全跳过 Langfuse，全链路零副作用（不建客户端、不发请求），
# 不是留空就报错或卡住——见 config.py 里 langfuse_handler() 的设计说明。
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
